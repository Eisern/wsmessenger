# ============================================================
#  WS Messenger — Server Configuration
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments.
# ============================================================

# ------------------------------------------------------------
#  REQUIRED — the server will refuse to start without these
# ------------------------------------------------------------

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/wsapp

# JWT signing secret(s).
# Single secret:
#   JWT_SECRET=<long random string>
# Multiple secrets with key IDs for rotation (kid:secret,...):
#   JWT_SECRETS=v1:<secret1>,v2:<secret2>
#   JWT_CURRENT_KID=v1
JWT_SECRET=REPLACE_WITH_YOUR_JWT_SECRET
# JWT_SECRETS=v1:secret1,v2:secret2
# JWT_CURRENT_KID=v1

# ------------------------------------------------------------
#  APP IDENTITY
# ------------------------------------------------------------

# Public base URL of this server (no trailing slash).
# Used in: room logo full URLs, admin panel CSP WebSocket header.
APP_BASE_URL=https://chat-room.work

# App name shown in TOTP authenticator apps (2FA QR code issuer).
APP_NAME=ChatRoom

# ------------------------------------------------------------
#  CORS — which web origins may call the REST API
#  Comma-separated list. chrome-extension:// is always allowed.
#  Leave empty if you only use the Chrome extension (no web clients).
# ------------------------------------------------------------
CORS_ORIGINS=https://chat-room.work,https://imagine-1-ws.xyz

# Set to 1 only if your web frontend sends cookies with requests.
# Cannot be used together with CORS_ORIGINS=* .
CORS_ALLOW_CREDENTIALS=0

# ------------------------------------------------------------
#  JWT TOKEN LIFETIMES
# ------------------------------------------------------------

# Access token lifetime in minutes (default: 10)
ACCESS_TOKEN_EXPIRES_MIN=10

# Refresh token lifetime in minutes (default: 10080 = 7 days)
REFRESH_TOKEN_EXPIRES_MIN=10080

# Legacy single-token lifetime, kept for compatibility (default: 1440 = 24h)
# JWT_EXPIRES_MIN=1440

# ------------------------------------------------------------
#  ARGON2id PASSWORD HASHING (server-side, for user passwords)
#  Defaults are safe — only change if you know what you're doing.
# ------------------------------------------------------------

# Argon2 variant: ID (default, recommended), I, or D
ARGON2_TYPE=ID

# Memory cost in KiB (default: 65536 = 64 MiB)
ARGON2_MEMORY_COST=65536

# Time cost / iterations (default: 3)
ARGON2_TIME_COST=3

# Parallelism / threads (default: 2)
ARGON2_PARALLELISM=2

# Salt size in bytes (default: 16)
ARGON2_SALT_SIZE=16

# Hash length in bytes (default: 32)
ARGON2_HASH_LEN=32

# ------------------------------------------------------------
#  RATE LIMITS (all have safe built-in defaults)
# ------------------------------------------------------------

# RL_WS_CONNECT_IP_PER_MIN=60
# RL_WS_DM_CONNECT_IP_PER_MIN=120
# RL_WS_DM_MSG_PER_10S=25
# RL_WS_DM_MSG_IP_PER_10S=60
# RL_FEEDBACK_IP_PER_10M=5
# RL_FEEDBACK_USER_PER_10M=3
# RL_ROOMS_INVITE_IP_PER_10MIN=60
# RL_ROOMS_INVITE_USER_PER_10MIN=20
# RL_TOTP_VERIFY_PER_MIN=10
# RL_TOTP_SETUP_PER_10MIN=5
# RL_DM_DELIVERY_SECRET_IP_PER_MIN=60
# RL_DM_DELIVERY_SECRET_USER_PER_MIN=30

# ------------------------------------------------------------
#  EMAIL / FEEDBACK (optional — feedback form sends emails)
# ------------------------------------------------------------

# FEEDBACK_TO=support@yourdomain.com
# SMTP_HOST=smtp.yourmail.com
# SMTP_PORT=587
# SMTP_USER=smtp-user
# SMTP_PASS=smtp-pass
# SMTP_FROM=WS Messenger <noreply@yourdomain.com>
# SMTP_TLS=1

# ------------------------------------------------------------
#  ENVIRONMENT
# ------------------------------------------------------------

# Set to "prod" to enable HSTS header (Strict-Transport-Security).
# Leave as "dev" for local development.
ENV=prod
