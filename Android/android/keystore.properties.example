# keystore.properties — copy to keystore.properties and fill in real values
# DO NOT commit keystore.properties to version control!

# Path to your release keystore file (relative to android/app/)
storeFile=release.keystore

# Passwords and alias (set when you ran keytool -genkey)
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
